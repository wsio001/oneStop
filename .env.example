# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Google Sheet ID - Irvine location (server-side only)
IRVINE_SHEET_ID=your-sheet-id-here

# Vercel KV Storage (get these from Vercel Dashboard → Storage → KV Database)
# After creating "onestop-sessions" database, copy these values:
KV_REST_API_URL=https://your-kv-database.upstash.io
KV_REST_API_TOKEN=your-rest-api-token-here
KV_URL=redis://default:your-token@your-kv-database.upstash.io

# App URL (for OAuth callback)
NEXT_PUBLIC_APP_URL=http://localhost:3000
